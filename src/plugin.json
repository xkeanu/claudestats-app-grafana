      },
      {
        "name": "license",
        "url": "https://github.com/tolzhabayev/claudestats-app-grafana/blob/HEAD/LICENSE"
      }
    ],
    "screenshots": [
      {
        "name": "Tokens",
        "path": "img/screenshots/screenshot-1.png"
      }
    ],
    "version": "%VERSION%",
    "updated": "%TODAY%"
